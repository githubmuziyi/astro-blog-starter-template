---
---

<div class="wechat-copy-wrapper">
  <button id="wechat-copy-trigger" class="copy-btn" title="复制到微信公众号" aria-label="Copy to WeChat">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-copy"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
    <span>微信复制</span>
  </button>

  <div id="wechat-copy-modal" class="modal-overlay hidden">
    <div class="modal-content">
      <div class="modal-header">
        <h3>复制到微信公众号</h3>
        <button id="wechat-modal-close" class="close-btn">&times;</button>
      </div>
      <div class="modal-body">
        <div class="form-group">
          <label for="wc-theme-color">主题颜色</label>
          <div class="color-picker-wrapper">
            <input type="color" id="wc-theme-color" value="#2BAE85" />
            <input type="text" id="wc-theme-color-text" value="#2BAE85" />
          </div>
        </div>

        <div class="form-group">
          <label for="wc-style">排版风格</label>
          <select id="wc-style">
            <option value="minimalist">Minimalist (极简)</option>
            <option value="focus" selected>Focus (专注)</option>
            <option value="exquisite">Exquisite (精致)</option>
            <option value="eye-catching">Eye-catching (醒目)</option>
          </select>
        </div>

        <div class="form-group">
          <label for="wc-font">字体</label>
          <select id="wc-font">
            <option value="default" selected>系统默认 (Default)</option>
            <option value="optima">Optima</option>
            <option value="georgia">Georgia</option>
          </select>
        </div>

        <div class="form-group">
          <label for="wc-font-size">基础字号 (px)</label>
          <input type="number" id="wc-font-size" value="16" min="12" max="24" />
        </div>

        <div class="form-group">
          <label for="wc-header-size">标题大小</label>
          <select id="wc-header-size">
            <option value="compact">Compact (紧凑)</option>
            <option value="streamlined">Streamlined (流畅)</option>
            <option value="standard" selected>Standard (标准)</option>
            <option value="prominent">Prominent (突出)</option>
          </select>
        </div>

        <div class="form-group">
          <label for="wc-paragraph-spacing">段落间距</label>
          <select id="wc-paragraph-spacing">
            <option value="compact">Compact (紧凑)</option>
            <option value="moderate" selected>Moderate (适中)</option>
            <option value="loose">Loose (宽松)</option>
          </select>
        </div>

        <div class="form-group checkbox-group">
          <input type="checkbox" id="wc-logo" />
          <label for="wc-logo">在文末添加 Logo</label>
        </div>
      </div>
      <div class="modal-footer">
        <button id="wechat-copy-confirm" class="confirm-btn">确认并复制</button>
      </div>
    </div>
  </div>
</div>

<style>
  .wechat-copy-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }
  
  .copy-btn {
    display: flex;
    align-items: center;
    gap: 0.5em;
    background: transparent;
    border: 1px solid var(--accent);
    color: var(--accent);
    padding: 0.4em 0.8em;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.9em;
    transition: all 0.2s ease;
    margin-right: 1em;
  }
  
  .copy-btn:hover {
    background: var(--accent);
    color: white;
  }

  .hidden {
    display: none !important;
  }

  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1000;
  }

  .modal-content {
    background: white;
    padding: 24px;
    border-radius: 12px;
    width: 90%;
    max-width: 400px;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    border-bottom: 1px solid #eee;
    padding-bottom: 12px;
  }

  .modal-header h3 {
    margin: 0;
    font-size: 1.2em;
    color: #333;
  }

  .close-btn {
    background: none;
    border: none;
    font-size: 1.5em;
    cursor: pointer;
    color: #999;
  }
  
  .close-btn:hover {
    color: #333;
  }

  .form-group {
    margin-bottom: 16px;
  }

  .form-group label {
    display: block;
    margin-bottom: 6px;
    font-size: 0.9em;
    color: #555;
    font-weight: 500;
  }

  .form-group select,
  .form-group input[type="number"],
  .form-group input[type="text"] {
    width: 100%;
    padding: 8px 12px;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 0.95em;
    box-sizing: border-box;
  }

  .color-picker-wrapper {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .color-picker-wrapper input[type="color"] {
    width: 40px;
    height: 40px;
    padding: 0;
    border: 1px solid #ddd;
    border-radius: 4px;
    cursor: pointer;
  }

  .checkbox-group {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 20px;
  }
  
  .checkbox-group label {
    margin-bottom: 0;
  }

  .modal-footer {
    margin-top: 24px;
    text-align: right;
  }

  .confirm-btn {
    background: var(--accent);
    color: white;
    border: none;
    padding: 10px 20px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 1em;
    font-weight: 500;
    width: 100%;
    transition: background 0.2s;
  }

  .confirm-btn:hover {
    background: #1a5cff; /* Fallback active color */
    filter: brightness(0.9);
  }

  .confirm-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }
</style>

<script>
  function initWeChatCopy() {
    const trigger = document.getElementById('wechat-copy-trigger');
    const modal = document.getElementById('wechat-copy-modal');
    const closeBtn = document.getElementById('wechat-modal-close');
    const confirmBtn = document.getElementById('wechat-copy-confirm');
    const colorInput = document.getElementById('wc-theme-color') as HTMLInputElement;
    const colorText = document.getElementById('wc-theme-color-text') as HTMLInputElement;

    if (!trigger || !modal) return;

    colorInput.addEventListener('input', (e) => {
      colorText.value = (e.target as HTMLInputElement).value;
    });
    colorText.addEventListener('input', (e) => {
      const val = (e.target as HTMLInputElement).value;
      if (/^#[0-9A-F]{6}$/i.test(val)) {
        colorInput.value = val;
      }
    });

    trigger.addEventListener('click', () => {
      modal.classList.remove('hidden');
    });

    closeBtn.addEventListener('click', () => {
      modal.classList.add('hidden');
    });

    modal.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.classList.add('hidden');
      }
    });

    confirmBtn.addEventListener('click', async () => {
      const originalText = confirmBtn.innerText;
      confirmBtn.innerText = '正在处理...';
      confirmBtn.setAttribute('disabled', 'true');

      try {
        await doWeChatCopy();
        confirmBtn.innerText = '复制成功!';
        setTimeout(() => {
          modal.classList.add('hidden');
          confirmBtn.innerText = originalText;
          confirmBtn.removeAttribute('disabled');
        }, 1500);
      } catch (err) {
        console.error(err);
        confirmBtn.innerText = '复制失败';
        setTimeout(() => {
          confirmBtn.innerText = originalText;
          confirmBtn.removeAttribute('disabled');
        }, 2000);
      }
    });
  }

  async function doWeChatCopy() {
    const options = {
      themeColor: (document.getElementById('wc-theme-color') as HTMLInputElement).value,
      style: (document.getElementById('wc-style') as HTMLSelectElement).value,
      font: (document.getElementById('wc-font') as HTMLSelectElement).value,
      fontSize: (document.getElementById('wc-font-size') as HTMLInputElement).value,
      headerSize: (document.getElementById('wc-header-size') as HTMLSelectElement).value,
      paragraphSpacing: (document.getElementById('wc-paragraph-spacing') as HTMLSelectElement).value,
      logo: (document.getElementById('wc-logo') as HTMLInputElement).checked,
    };

    let fontFamily = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif';
    if (options.font === 'optima') fontFamily = 'Optima, "Segoe UI", Roboto, Arial, sans-serif';
    if (options.font === 'georgia') fontFamily = 'Georgia, serif';

    let lh = 1.6;
    let pMargin = '16px';
    if (options.paragraphSpacing === 'compact') { lh = 1.5; pMargin = '12px'; }
    if (options.paragraphSpacing === 'loose') { lh = 1.8; pMargin = '24px'; }

    let h1Size = '2em', h2Size = '1.5em', h3Size = '1.25em';
    let hMargin = '24px';
    if (options.headerSize === 'compact') { h1Size = '1.5em'; h2Size = '1.3em'; h3Size = '1.1em'; hMargin = '16px'; }
    if (options.headerSize === 'streamlined') { h1Size = '1.75em'; h2Size = '1.4em'; h3Size = '1.2em'; hMargin = '20px'; }
    if (options.headerSize === 'prominent') { h1Size = '2.2em'; h2Size = '1.8em'; h3Size = '1.5em'; hMargin = '32px'; }

    const proseDiv = document.querySelector('.prose');
    if (!proseDiv) throw new Error("Article content not found");

    const container = document.createElement('div');
    container.className = 'wechat-container';
    container.innerHTML = proseDiv.innerHTML;

    const apply = (selector: string, styles: any) => {
      container.querySelectorAll(selector).forEach(el => {
        Object.assign((el as HTMLElement).style, styles);
      });
    };

    Object.assign(container.style, {
      fontFamily: fontFamily,
      fontSize: options.fontSize + 'px',
      lineHeight: String(lh),
      color: '#3f3f3f',
      wordWrap: 'break-word',
      padding: '15px'
    });

    apply('p', { marginTop: '0', marginBottom: pMargin, letterSpacing: '0.5px' });
    apply('strong', { color: options.themeColor, fontWeight: 'bold' });
    apply('em', { fontStyle: 'italic', color: '#888' });
    apply('a', { color: options.themeColor, textDecoration: 'none', borderBottom: `1px solid ${options.themeColor}` });
    apply('hr', { border: 'none', borderTop: '1px solid #eaecef', margin: '24px 0' });
    apply('h1, h2, h3', { marginTop: hMargin, marginBottom: '16px', fontWeight: 'bold', color: '#1a1a1a' });
    apply('h1', { fontSize: h1Size });
    apply('h2', { fontSize: h2Size });
    apply('h3', { fontSize: h3Size });
    apply('ul, ol', { paddingLeft: '2em', marginTop: '0', marginBottom: pMargin });
    apply('li', { marginBottom: '0.25em' });
    apply('img', { maxWidth: '100%', height: 'auto', display: 'block', margin: `${pMargin} auto`, borderRadius: '8px' });
    apply('code', { padding: '0.2em 0.4em', backgroundColor: 'rgba(27,31,35,0.05)', borderRadius: '3px', fontFamily: '"SFMono-Regular", Consolas, "Liberation Mono", Menlo, Courier, monospace', fontSize: '85%', color: '#d14' });
    apply('pre', { padding: '16px', overflow: 'auto', fontSize: '85%', lineHeight: '1.45', backgroundColor: '#f6f8fa', borderRadius: '6px', marginBottom: pMargin });
    apply('pre code', { padding: '0', backgroundColor: 'transparent', color: '#333' });

    if (options.style === 'minimalist') {
      apply('blockquote', { borderLeft: '4px solid #dfe2e5', padding: '5px 1em', color: '#6a737d', margin: `0 0 ${pMargin}` });
      apply('h2', { borderBottom: '1px solid #eaecef', paddingBottom: '0.3em' });
    } else if (options.style === 'focus') {
      apply('blockquote', { borderLeft: `4px solid ${options.themeColor}`, padding: '10px 15px', color: '#555', backgroundColor: '#f9f9f9', margin: `0 0 ${pMargin}`, borderRadius: '4px' });
      apply('h2', { display: 'block', borderLeft: `4px solid ${options.themeColor}`, paddingLeft: '10px', marginBottom: '20px' });
    } else if (options.style === 'exquisite') {
      apply('blockquote', { padding: '15px', borderRadius: '8px', background: 'rgba(0,0,0,0.03)', color: '#666', margin: `0 0 ${pMargin}`, border: '1px solid #eee' });
      apply('h2', { backgroundColor: options.themeColor, color: '#fff', padding: '6px 14px', borderRadius: '6px', display: 'inline-block', marginBottom: '15px', fontSize: '1.1em' });
      apply('strong', { borderBottom: '2px rgba(255,0,0,0.2) dashed' });
    } else if (options.style === 'eye-catching') {
      apply('blockquote', { borderLeft: `6px solid ${options.themeColor}`, padding: '15px', background: 'rgba(0,0,0,0.04)', margin: `0 0 ${pMargin}`, color: '#333', fontWeight: 'bold' });
      apply('h2', { textAlign: 'center', color: options.themeColor, marginTop: '32px', marginBottom: '24px', position: 'relative' });
      
      container.querySelectorAll('h2').forEach(h2 => {
        const after = document.createElement('div');
        Object.assign(after.style, { display: 'block', width: '50px', height: '3px', backgroundColor: options.themeColor, margin: '8px auto 0' });
        h2.appendChild(after);
      });
    } else {
      apply('blockquote', { borderLeft: `4px solid ${options.themeColor}`, padding: '10px 15px', backgroundColor: '#f8f8f8', margin: `0 0 ${pMargin}` });
    }

    if (options.logo) {
      const footer = document.createElement('div');
      footer.innerHTML = '<p style="text-align:center; font-size:12px; color:#999; margin-top: 40px;">Generated by Your custom MD CLI</p>';
      container.appendChild(footer);
    }

    const images = container.querySelectorAll('img');
    for (let i = 0; i < images.length; i++) {
      const img = images[i] as HTMLImageElement;
      if (!img.src.startsWith('data:')) {
        try {
          const res = await fetch(img.src);
          const blob = await res.blob();
          const reader = new FileReader();
          const base64 = await new Promise((resolve) => {
            reader.onloadend = () => resolve(reader.result);
            reader.readAsDataURL(blob);
          });
          img.src = base64 as string;
          img.style.maxWidth = '100%';
          img.style.height = 'auto';
        } catch (e) {
          console.error("Failed to fetch/encode image:", img.src, e);
        }
      }
    }

    const htmlString = container.outerHTML;
    
    if (navigator.clipboard && window.ClipboardItem) {
      const blobHtml = new Blob([htmlString], { type: 'text/html' });
      const blobText = new Blob([container.innerText], { type: 'text/plain' });
      const data = [new ClipboardItem({ 'text/html': blobHtml, 'text/plain': blobText })];
      await navigator.clipboard.write(data);
    } else {
      const tempElement = document.createElement('div');
      tempElement.contentEditable = 'true';
      tempElement.innerHTML = htmlString;
      document.body.appendChild(tempElement);
      
      const range = document.createRange();
      range.selectNodeContents(tempElement);
      const selection = window.getSelection();
      selection?.removeAllRanges();
      selection?.addRange(range);
      
      document.execCommand('copy');
      
      selection?.removeAllRanges();
      document.body.removeChild(tempElement);
    }
  }

  document.addEventListener('astro:page-load', initWeChatCopy);
  // Also run initially
  initWeChatCopy();
</script>